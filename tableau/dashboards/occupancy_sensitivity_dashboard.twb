      <aliases enabled='yes' />
      <column caption='Airbnb Yroi New' datatype='real' name='[AIRBNB_YROI_NEW]' role='dimension' type='quantitative' />
      <column caption='Annual_Airbnb__Rent_New' datatype='real' name='[ANNUAL_AIRBNB__RENT_NEW]' role='dimension' type='quantitative' />
      <column caption='ADJ_AIRBNB_NEW' datatype='real' name='[Calculation_1573726622151176192]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([AIRBNB_YROI_NEW]* [HOUSE PRICE])+([SERVICE COST NEW] + [LOCAL ANNUAL  TAXES]))* ((100+&#13;&#10;[Parameters].[Parametro 2])/100) / [HOUSE PRICE]' />
      </column>
      <column caption='Loan amount' datatype='real' name='[Calculation_1573726622161829889]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parametro 1] - 200000' />
      </column>
      <column caption='Loan Interest' datatype='real' name='[Calculation_1573726622162026498]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1573726622161829889] * [Parameters].[Parametro 3]' />
      </column>
      <column caption='Remaning Budget' datatype='real' name='[Calculation_1573726622162219011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parametro 1] - ([Calculation_1573726622161829889] + [Calculation_1573726622162026498])' />
      </column>
      <column caption='Adjusted Occupancy  Rate ' datatype='real' name='[Calculation_1573726622367653892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Occupancy Rate] + [Parameters].[Parametro 2]' />
      </column>
      <column caption='Difference' datatype='real' name='[Calculation_1573726622546718729]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parametro 1] - [HOUSE PRICE]' />
      </column>
      <column caption='ORDER' datatype='integer' name='[Calculation_1879408448305655813]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK_UNIQUE(AVG([Calculation_1573726622151176192]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Color Investment' datatype='string' name='[Calculation_1879408448333033486]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_511721536328683521] &lt; 0 THEN &quot;Red&quot;&#13;&#10;ELSE &quot;Green&quot;&#13;&#10;END' />
      </column>
      <column caption='Difference Total' datatype='real' name='[Calculation_511721536328683521]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Parameters].[Parametro 1]- SUM([HOUSE PRICE])' />
      </column>
      <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
