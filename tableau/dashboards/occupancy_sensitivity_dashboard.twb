  <worksheets>
    <worksheet name='City and House for ADJ_AIRBNB_YROI'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#4e79a7' fontsize='16'>City for Occ.Rate  and Top 10 Housetype order by ADJ_AIRBNB_YROI</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Flow 1 copia 2 (Output flow 1 copia 2)' name='federated.1obvrwz00fxi7l19qb4ti07gnjp1' />
            <datasource caption='Parametri' name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='OC_RATE_VAR_NEW' datatype='real' default-format='p0.00%' name='[Parametro 2]' param-domain-type='range' role='measure' type='quantitative' value='0.'>
              <calculation class='tableau' formula='0.' />
              <range granularity='0.01' max='0.05' min='-0.05' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1obvrwz00fxi7l19qb4ti07gnjp1'>
            <column caption='Airbnb Yroi New' datatype='real' name='[AIRBNB_YROI_NEW]' role='dimension' type='quantitative' />
            <column caption='ADJ_AIRBNB_NEW' datatype='real' name='[Calculation_1573726622151176192]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(([AIRBNB_YROI_NEW]* [HOUSE PRICE])+([SERVICE COST NEW] + [LOCAL ANNUAL  TAXES]))* ((100+&#13;&#10;[Parameters].[Parametro 2])/100) / [HOUSE PRICE]' />
            </column>
            <column caption='ORDER' datatype='integer' name='[Calculation_1879408448305655813]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='RANK_UNIQUE(AVG([Calculation_1573726622151176192]), &apos;desc&apos;)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='string' name='[City]' role='dimension' semantic-role='[City].[Name]' type='nominal' />
            <column caption='House Price' datatype='real' name='[HOUSE PRICE]' role='measure' type='quantitative' />
            <column datatype='string' name='[House Type]' role='dimension' type='nominal' />
            <column caption='Local Annual  Taxes' datatype='real' name='[LOCAL ANNUAL  TAXES]' role='measure' type='quantitative' />
            <column caption='Service Cost New' datatype='real' name='[SERVICE COST NEW]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1573726622151176192]' derivation='Avg' name='[avg:Calculation_1573726622151176192:qk]' pivot='key' type='quantitative' />
            <column-instance column='[City]' derivation='None' name='[none:City:nk]' pivot='key' type='nominal' />
            <column-instance column='[House Type]' derivation='None' name='[none:House Type:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1879408448305655813]' derivation='User' name='[usr:Calculation_1879408448305655813:qk:6]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.1obvrwz00fxi7l19qb4ti07gnjp1].[House Type]' ordering-type='Field' />
            </column-instance>
          </datasource-dependencies>
          <filter class='quantitative' column='[federated.1obvrwz00fxi7l19qb4ti07gnjp1].[avg:Calculation_1573726622151176192:qk]' included-values='in-range'>
            <min>0.059999999999999998</min>
            <max>5.037027012644562</max>
          </filter>
          <filter class='categorical' column='[federated.1obvrwz00fxi7l19qb4ti07gnjp1].[none:City:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
