      <column caption='INDEX' datatype='real' name='[Calculation_1242993511040069633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[AIRBNB_YROI]/[RENT_YROI]' />
      </column>
      <column caption='NEW INDEX' datatype='real' name='[Calculation_1404560147929165825]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1404560147936325635] / [RENT_YROI]' />
      </column>
      <column caption='ADJ_AIRBNB_YROI' datatype='real' name='[Calculation_1404560147936325635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(([AIRBNB_YROI] * [HOUSE PRICE]) + ([AIRNBN_SERVICE_COST] + [LOCAL ANNUAL  TAXES])) * ((100+[Parameters].[Parametro 1])/100) / [HOUSE PRICE]' />
